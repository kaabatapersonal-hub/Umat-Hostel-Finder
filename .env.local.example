# Copy to .env.local and fill in real values. Never commit .env.local itself
# (it's gitignored) -- this file is the only one meant to be tracked, and it
# must only ever contain placeholders.

# Required. Supabase project URL and anon (public) key -- find both under
# Project Settings -> API. The anon key is safe to expose client-side; RLS
# is what actually protects the data (see SECURITY.md).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional -- transactional email (Session 11 submission approve/reject
# notifications). Leave unset and the app no-ops the email step silently;
# nothing else depends on it. Get a key from resend.com. NEVER prefix this
# with NEXT_PUBLIC_ -- it must stay server-only (see src/lib/email.ts).
RESEND_API_KEY=
RESEND_FROM_EMAIL=Campa <notifications@yourdomain.com>

# Optional -- used to build absolute URLs (email links, sitemap.xml,
# metadataBase for OG images). Falls back to Vercel's own VERCEL_URL, then
# localhost, if unset.
NEXT_PUBLIC_SITE_URL=https://your-production-domain.com
